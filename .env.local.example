# ─── Next Auth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Database (Render Postgres connection string) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/wgu_staging

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=wgu-staging-files
# Optional: public bucket URL if you enable R2 public access
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── App Config ───────────────────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=wgu.edu
